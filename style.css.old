/* 
  Sarang Church Mobile Web App - Design System
  Theme: Wood & White
*/

:root {
  --primary-wood: #8B5A2B;
  --secondary-wood: #D2B48C;
  --light-wood: #F5F5DC;
  --dark-wood: #5D4037;
  --white: #FFFFFF;
  --off-white: #FAFAFA;
  --text-main: #3E2723;
  --text-muted: #795548;
  --shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
  --border-radius: 12px;
  --transition: all 0.3s ease;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

body {
  font-family: 'Noto Sans KR', sans-serif;
  background-color: var(--white);
  color: var(--text-main);
  line-height: 1.6;
  overflow-x: hidden;
  display: flex;
  justify-content: center;
}

#app {
  width: 100%;
  max-width: 480px;
  /* Mobile Viewport Limit */
  min-height: 100vh;
  background: var(--white);
  position: relative;
  display: flex;
  flex-direction: column;
}

/* Header */
header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(139, 90, 43, 0.1);
}

.header-left {
  width: 40px;
  height: 40px;
}

.header-left img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.header-center h1 {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--primary-wood);
  letter-spacing: -0.5px;
}

.header-right {
  width: 40px;
}

/* Navigation Overlay */
.nav-menu {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 480px;
  background: var(--white);
  display: flex;
  justify-content: space-around;
  padding: 10px 0 25px;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.03);
  z-index: 99;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  color: var(--text-muted);
  font-size: 0.7rem;
  gap: 4px;
}

.nav-item.active {
  color: var(--primary-wood);
  font-weight: 600;
}

.nav-item i {
  font-size: 1.2rem;
}

/* Content Area */
main {
  flex: 1;
  padding-bottom: 80px;
  /* Space for bottom nav */
}

.page {
  display: none;
  animation: fadeIn 0.4s ease;
}

.page.active {
  display: block;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Hero Section */
.hero {
  position: relative;
  height: 250px;
  overflow: hidden;
  margin-bottom: 24px;
}

.hero img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40px 20px 20px;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  color: white;
}

.hero-overlay h2 {
  font-size: 1.4rem;
  margin-bottom: 4px;
}

/* Section Cards */
section {
  padding: 0 20px;
  margin-bottom: 32px;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--dark-wood);
}

.card {
  background: var(--off-white);
  border-radius: var(--border-radius);
  padding: 20px;
  border: 1px solid rgba(139, 90, 43, 0.05);
  box-shadow: var(--shadow);
}

/* Quick Menu Grid */
.quick-menu {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: -40px;
  position: relative;
  z-index: 10;
  padding: 0 20px;
  margin-bottom: 32px;
}

.quick-item {
  background: var(--white);
  padding: 16px 8px;
  border-radius: var(--border-radius);
  text-align: center;
  box-shadow: var(--shadow);
  text-decoration: none;
  color: var(--text-main);
}

.quick-item i {
  font-size: 1.5rem;
  color: var(--primary-wood);
  margin-bottom: 8px;
  display: block;
}

.quick-item span {
  font-size: 0.8rem;
  font-weight: 500;
}

/* Service Table */
.service-table {
  width: 100%;
  border-collapse: collapse;
}

.service-table th,
.service-table td {
  padding: 12px;
  text-align: left;
  border-bottom: 1px solid rgba(139, 90, 43, 0.1);
}

.service-table th {
  color: var(--primary-wood);
  font-weight: 600;
}

/* Offering Card */
.offering-card {
  background: linear-gradient(135deg, var(--primary-wood), var(--dark-wood));
  color: white;
  padding: 24px;
  border-radius: var(--border-radius);
  margin-bottom: 16px;
}

.account-box {
  background: rgba(255, 255, 255, 0.1);
  padding: 12px;
  border-radius: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
}

.copy-btn {
  background: var(--white);
  color: var(--primary-wood);
  border: none;
  padding: 4px 12px;
  border-radius: 4px;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
}

/* Map Placeholder */
.map-placeholder {
  width: 100%;
  height: 200px;
  background: var(--light-wood);
  border-radius: var(--border-radius);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: var(--primary-wood);
  border: 1px dashed var(--secondary-wood);
}

/* List Style */
.news-list {
  list-style: none;
}

.news-item {
  padding: 16px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 12px;
}

.news-date {
  font-size: 0.75rem;
  color: var(--text-muted);
  min-width: 60px;
}

.news-content h4 {
  font-size: 0.95rem;
  margin-bottom: 4px;
}

/* Youtube Embed Wrapper */
.video-wrapper {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  border-radius: var(--border-radius);
  overflow: hidden;
  box-shadow: var(--shadow);
}

.video-wrapper iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* Utils */
.mb-2 {
  margin-bottom: 8px;
}

.mt-2 {
  margin-top: 8px;
}

.text-center {
  text-align: center;
}